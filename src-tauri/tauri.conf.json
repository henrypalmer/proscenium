{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Proscenium",
  "version": "0.1.0",
  "identifier": "com.proscenium.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Proscenium",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "app", "dmg"],
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "createUpdaterArtifacts": true,
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU2QkQ3QzBBNDVFNUQ3RDgKUldUWTErVkZDbnk5NWtkUUY5WlN3Q1dQbTA0Ty9FYUpNN0VhalNsQlFJaVJNMXhsUEh4K2s4d0sK",
      "endpoints": [
        "https://releases.proscenium.app/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  }
}
